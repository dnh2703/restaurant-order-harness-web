# Backend (Elysia/Bun) base URL — used by server functions to proxy API calls.
API_BASE_URL=http://localhost:3000

# Optional: a seeded table QR token to enable the happy-path Playwright e2e.
# Seed the BE first (`bun run db:seed` in restaurant-order-harness-server →
# fixed tokens qr-table-01..03), then:
#   E2E_QR_TOKEN=qr-table-01 bun run test:e2e
# Without it, the token-dependent e2e tests skip cleanly (CI-safe).

# Optional: admin credentials for US-1.3 table-QR e2e (seed: admin@demo.test / admin-password).
# E2E_ADMIN_EMAIL=admin@demo.test
# E2E_ADMIN_PASSWORD=admin-password
