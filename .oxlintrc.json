{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "import"],
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "react/no-unknown-property": "error"
  },
  "ignorePatterns": [
    "src/routeTree.gen.ts",
    ".agents/**",
    ".output/**",
    "dist/**",
    ".vite/**",
    "node_modules/**"
  ]
}
